{
  "$schema": "/indexing/entities/entity_definition_schema.v1.json",
  "source": {
    "from": "record",
    "recordKind": "event",
    "recordName": "SwapEvent"
  },
  "transform": {
    "extract": {
      "recordId": "$raw.record_id",
      "signature": "$raw.signature",
      "pool": "$raw.subject_id",
      "trader": "$payload.trader",
      "side": "$payload.side",
      "eventTime": "$raw.event_time",
      "aToB": "$payload.aToB",
      "inputAmountAtomic": "$payload.inputAmountAtomic",
      "outputAmountAtomic": "$payload.outputAmountAtomic",
      "inputTransferFeeAtomic": "$payload.inputTransferFeeAtomic",
      "outputTransferFeeAtomic": "$payload.outputTransferFeeAtomic",
      "preSqrtPrice": "$payload.preSqrtPrice",
      "postSqrtPrice": "$payload.postSqrtPrice",
      "lpFeeAtomic": "$payload.lpFeeAtomic",
      "protocolFeeAtomic": "$payload.protocolFeeAtomic"
    }
  },
  "emit": {
    "id": "recordId",
    "indexes": [
      ["pool", "eventTime:desc"],
      ["trader", "eventTime:desc"]
    ],
    "timeField": "eventTime",
    "defaultOrderBy": ["eventTime:desc"],
    "fields": {
      "recordId": { "type": "TEXT", "primaryKey": true, "filterable": true },
      "signature": { "type": "TEXT", "filterable": true },
      "pool": { "type": "TEXT", "filterable": true },
      "trader": { "type": "TEXT", "filterable": true },
      "side": { "type": "TEXT" },
      "eventTime": { "type": "TIMESTAMPTZ", "filterable": true },
      "aToB": { "type": "BOOLEAN" },
      "inputAmountAtomic": { "type": "NUMERIC" },
      "outputAmountAtomic": { "type": "NUMERIC" },
      "inputTransferFeeAtomic": { "type": "NUMERIC" },
      "outputTransferFeeAtomic": { "type": "NUMERIC" },
      "preSqrtPrice": { "type": "NUMERIC" },
      "postSqrtPrice": { "type": "NUMERIC" },
      "lpFeeAtomic": { "type": "NUMERIC" },
      "protocolFeeAtomic": { "type": "NUMERIC" }
    }
  }
}
