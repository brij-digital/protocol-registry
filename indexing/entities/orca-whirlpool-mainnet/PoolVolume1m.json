{
  "$schema": "/indexing/entities/entity_definition_schema.v1.json",
  "retention": "365d",
  "source": {
    "from": "record",
    "recordKind": "event",
    "recordName": "SwapEvent"
  },
  "transform": {
    "extract": {
      "pool": "$raw.subject_id",
      "aToB": "$payload.aToB",
      "inputAmountAtomic": "$payload.inputAmountAtomic",
      "outputAmountAtomic": "$payload.outputAmountAtomic",
      "lpFeeAtomic": "$payload.lpFeeAtomic",
      "protocolFeeAtomic": "$payload.protocolFeeAtomic",
      "eventTime": "$raw.event_time"
    },
    "compute": [
      {
        "ref": "time.bucket",
        "inputs": {
          "value": "$ctx.eventTime",
          "interval": "1m"
        },
        "output": "bucketStart"
      },
      {
        "ref": "logic.if_then_else",
        "inputs": {
          "condition": "$ctx.aToB",
          "then_value": "$ctx.inputAmountAtomic",
          "else_value": "$ctx.outputAmountAtomic"
        },
        "output": "volumeTokenAAtomic"
      },
      {
        "ref": "logic.if_then_else",
        "inputs": {
          "condition": "$ctx.aToB",
          "then_value": "$ctx.outputAmountAtomic",
          "else_value": "$ctx.inputAmountAtomic"
        },
        "output": "volumeTokenBAtomic"
      }
    ],
    "groupBy": [
      "pool",
      "bucketStart"
    ],
    "reduce": {
      "volumeTokenAAtomic": {
        "op": "sum",
        "value": "$ctx.volumeTokenAAtomic"
      },
      "volumeTokenBAtomic": {
        "op": "sum",
        "value": "$ctx.volumeTokenBAtomic"
      },
      "lpFeeAtomic": {
        "op": "sum",
        "value": "$ctx.lpFeeAtomic"
      },
      "protocolFeeAtomic": {
        "op": "sum",
        "value": "$ctx.protocolFeeAtomic"
      },
      "tradeCount": {
        "op": "count"
      },
      "firstEventTime": {
        "op": "min",
        "value": "$ctx.eventTime"
      },
      "lastEventTime": {
        "op": "max",
        "value": "$ctx.eventTime"
      }
    }
  },
  "emit": {
    "id": [
      "pool",
      "bucketStart"
    ],
    "indexes": [
      [
        "pool",
        "bucketStart:desc"
      ]
    ],
    "timeField": "bucketStart",
    "defaultOrderBy": [
      "bucketStart:desc"
    ],
    "fields": {
      "pool": {
        "type": "TEXT",
        "primaryKey": true,
        "filterable": true
      },
      "bucketStart": {
        "type": "TIMESTAMPTZ",
        "primaryKey": true,
        "filterable": true
      },
      "volumeTokenAAtomic": {
        "type": "NUMERIC"
      },
      "volumeTokenBAtomic": {
        "type": "NUMERIC"
      },
      "lpFeeAtomic": {
        "type": "NUMERIC"
      },
      "protocolFeeAtomic": {
        "type": "NUMERIC"
      },
      "tradeCount": {
        "type": "BIGINT"
      },
      "firstEventTime": {
        "type": "TIMESTAMPTZ"
      },
      "lastEventTime": {
        "type": "TIMESTAMPTZ"
      }
    }
  }
}
