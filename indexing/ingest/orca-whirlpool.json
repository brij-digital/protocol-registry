{
  "$schema": "/schemas/declarative_decoder_runtime.schema.v1.json",
  "schema": "declarative-decoder-runtime.v1",
  "version": "0.1.0",
  "protocolId": "orca-whirlpool-mainnet",
  "label": "Orca Whirlpool Declarative Runtime",
  "programId": "$protocol.programId",
  "decoderArtifacts": {
    "orca_whirlpool": {
      "kind": "generated_idl_decoder",
      "family": "codama",
      "codamaPath": "/codama/orca-whirlpool.json",
      "artifact": "orca_whirlpool"
    }
  },
  "sources": {
    "orca_whirlpool_crawler": {
      "kind": "rpc_transaction_crawler",
      "programId": "$protocol.programId",
      "commitment": "confirmed",
      "decoderRef": "orca_whirlpool",
      "decodeTargets": [
        "instruction",
        "log_event"
      ],
      "filters": {}
    }
  },
  "matchRules": [
    {
      "source": "orca_whirlpool_crawler",
      "match": {
        "decodedType": "event",
        "name": "TradedEvent"
      },
      "pipeline": "whirlpool_trade"
    }
  ],
  "pipelines": {
    "whirlpool_trade": {
      "extract": {
        "pool": "$decoded.whirlpool",
        "marketType": "whirlpool",
        "trader": "$update.signer",
        "aToB": "$decoded.a_to_b",
        "inputAmountAtomic": "$decoded.input_amount",
        "outputAmountAtomic": "$decoded.output_amount",
        "inputTransferFeeAtomic": "$decoded.input_transfer_fee",
        "outputTransferFeeAtomic": "$decoded.output_transfer_fee",
        "preSqrtPrice": "$decoded.pre_sqrt_price",
        "postSqrtPrice": "$decoded.post_sqrt_price",
        "lpFeeAtomic": "$decoded.lp_fee",
        "protocolFeeAtomic": "$decoded.protocol_fee",
        "signature": "$update.signature",
        "slot": "$update.slot",
        "observedAt": "$update.eventTime"
      },
      "compute": [
        {
          "name": "side",
          "compute": "logic.if",
          "condition": "$ctx.aToB",
          "then": "a_to_b",
          "else": "b_to_a"
        }
      ],
      "emit": {
        "record": {
          "recordKind": "event",
          "recordName": "SwapEvent",
          "subjectId": "$ctx.pool",
          "resourceId": "$ctx.pool",
          "participantId": "$ctx.trader",
          "signature": "$ctx.signature",
          "slot": "$ctx.slot",
          "eventTime": "$ctx.observedAt",
          "payload": {
            "pool": "$ctx.pool",
            "marketType": "$ctx.marketType",
            "trader": "$ctx.trader",
            "side": "$side",
            "aToB": "$ctx.aToB",
            "inputAmountAtomic": "$ctx.inputAmountAtomic",
            "outputAmountAtomic": "$ctx.outputAmountAtomic",
            "inputTransferFeeAtomic": "$ctx.inputTransferFeeAtomic",
            "outputTransferFeeAtomic": "$ctx.outputTransferFeeAtomic",
            "preSqrtPrice": "$ctx.preSqrtPrice",
            "postSqrtPrice": "$ctx.postSqrtPrice",
            "lpFeeAtomic": "$ctx.lpFeeAtomic",
            "protocolFeeAtomic": "$ctx.protocolFeeAtomic",
            "signature": "$ctx.signature",
            "slot": "$ctx.slot",
            "observedAt": "$ctx.observedAt"
          }
        },
        "state": {
          "recordKind": "state",
          "recordName": "WhirlpoolTradeState",
          "subjectId": "$ctx.pool",
          "resourceId": "$ctx.pool",
          "signature": "$ctx.signature",
          "slot": "$ctx.slot",
          "eventTime": "$ctx.observedAt",
          "payload": {
            "pool": "$ctx.pool",
            "marketType": "$ctx.marketType",
            "side": "$side",
            "aToB": "$ctx.aToB",
            "inputAmountAtomic": "$ctx.inputAmountAtomic",
            "outputAmountAtomic": "$ctx.outputAmountAtomic",
            "inputTransferFeeAtomic": "$ctx.inputTransferFeeAtomic",
            "outputTransferFeeAtomic": "$ctx.outputTransferFeeAtomic",
            "preSqrtPrice": "$ctx.preSqrtPrice",
            "postSqrtPrice": "$ctx.postSqrtPrice",
            "lpFeeAtomic": "$ctx.lpFeeAtomic",
            "protocolFeeAtomic": "$ctx.protocolFeeAtomic",
            "observedAt": "$ctx.observedAt"
          }
        }
      }
    }
  }
}
